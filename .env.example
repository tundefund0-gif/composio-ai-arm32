# ─── Zen Agent — Environment Variables ──────────────────────────
# Copy this to .env and fill in your keys

# ── Required: LLM API ────────────────────────────────────────
OPENGATE_API_KEY=your-opencode-api-key-here
OPENGATE_BASE_URL=https://opencode.ai/zen/v1
OPENGATE_MODEL=big-pickle
OPENGATE_MAX_TOKENS=131072

# ── Optional: Fallback LLM (used when primary fails) ──────────
# OPENGATE_FALLBACK_MODEL=gpt-4o-mini
# OPENGATE_FALLBACK_BASE_URL=https://api.openai.com/v1
# OPENGATE_FALLBACK_API_KEY=sk-your-fallback-key

# ── Required: Composio API (for 23,790+ tools) ───────────────
COMPOSIO_API_KEY=your-composio-api-key-here
COMPOSIO_BASE_URL=https://backend.composio.dev

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9090
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60

# ── Data & Persistence ──────────────────────────────────────
DATA_DIR=./data

# ── Limits ───────────────────────────────────────────────────
MAX_HISTORY_MESSAGES=100
MAX_TOOL_RESULTS_LENGTH=15000
MAX_MESSAGE_LENGTH=100000
REQUEST_TIMEOUT=300.0
LLM_TIMEOUT=300.0

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FORMAT=json  # uncomment for structured JSON logging
